<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <% if (user){ %>
        <h1>Browse movies</h1>
        <a href="/movies/new">Add Movie</a>
    <% }%>

    <% if (!user) { %>
        <h1> browse movies</h1>
    <% }%>

    <% allMovies.forEach((item) => { %>
        <ul>
            <img src="<%= item.posterURL %>" width="200px">
        <h3> <%= item.title %> </h3>
        <p>created by: <%= item.owner.username %> </p>
        
        </ul>
    <% }) %>
</body>
</html>

