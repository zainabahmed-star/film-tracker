<%- include('../partials/nav.ejs') %>

    
<div class="movie-up" style="background-image: linear-gradient(180deg, rgba(20,24,28,0.2) 0%, rgba(20,24,28,0.95) 85%), url('<%= foundmovie.image.url %>')">
  <div class="movie-up-content">
    <div class="movie-card">
      <img src="<%= foundmovie.image.url %>">
    </div>

    <div class="movie-content">
      <h1 class="movie-title"><%= foundmovie.title %></h1>
      <p class="movie-data">
        <span><%= foundmovie.releaseYear %></span>
        <span class="dot">•</span>
        <span>Added by: <%= foundmovie.owner.username %></span>
      </p>
      <p class="movie-genre"><%= foundmovie.genre %></p>

      <% if (user) { %>
        <div class="actions">
          <a class="btn btn-outline-success btn-sm" href="/movies/<%= foundmovie._id %>/reviews/new">Write a Review</a>

           <% if (inWatchlist) { %>
            
             <form action="/watchlist/<%= foundmovie._id %>" method="POST">
            <button class="icon-btn btn btn-success btn-sm"  title="Add to Watchlist">In Watchlist</button>
          </form>
             <% } else { %> 
          <form action="/watchlist/<%= foundmovie._id %>" method="POST">
            <button type="submit" class="icon-btn btn btn-secondary btn-sm"  title="Add to Watchlist">+ Watchlist</button>
          </form>
           <% } %>

           <% if (inWatched) { %>
            <form action="/watched/<%= foundmovie._id %>" method="POST">
            <button class="icon-btn btn btn-success btn-sm" title="Mark as Watched">✓ Watched</button>
          </form>
 <% } else { %> 
          <form action="/watched/<%= foundmovie._id %>" method="POST">
            <button type="submit" class="icon-btn btn btn-secondary btn-sm" title="Mark as Watched">Mark as Watched</button>
          </form>
       <% } %>
        </div>
      <% } %>
    </div>
  </div>
</div>

<div class="movieBody">
    <% if (user && foundmovie.owner._id.equals(user._id)) { %>
        <div class="user-section">
            <a href="/movies/<%= foundmovie._id %>/edit">Edit this Movie</a>
            <a href="/movies/<%= foundmovie._id %>/delete" class="link-button">Delete Movie</a>
        </div>
        

     <% } %>   
</div>

<section class="reviews-section">
    <h3 class="section-label">Reviews</h3>

    <% if (foundreview.length === 0) { %>
        <p class="empty-state">No reviews yet — be the first to log this film.</p>
    <% } %>

    <% foundreview.forEach(review => { %>
        <div class="review-card">
            <div class="review-header">
                <span class="review-author"><%= review.user.username %></span>
                <span class="review-rating"><%= review.rating %>/5 ★</span>
            </div>
            <p class="review-text"><%= review.text %></p>

            <% if (user && review.user._id.equals(user._id)) { %>
                <div class="review-actions">
                    <a href="/movies/<%= foundmovie._id %>/reviews/<%= review._id %>/edit">Edit</a>
                    <form action="/movies/<%= foundmovie._id %>/reviews/<%= review._id %>?_method=DELETE" method="POST">
                        <button type="submit">Delete</button>
                    </form>
                </div>
            <% } %>
        </div>
    <% }) %>
</section>



    
    




   

   
</body>
</html>